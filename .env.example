# ---------------------------------------------------------------------------
# Supabase (required to persist screen results)
# Project Settings -> API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is used ONLY server-side (API route / cron) to write rows.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Free data API keys (optional but recommended)
# The screener degrades gracefully: any missing key disables that one signal.
# ---------------------------------------------------------------------------
# Finnhub free tier (60 req/min): earnings calendar + insider transactions
#   https://finnhub.io/register
FINNHUB_API_KEY=
# Alpha Vantage free tier (25 req/day): NEWS_SENTIMENT
#   https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# ---------------------------------------------------------------------------
# Screener config (optional overrides)
# ---------------------------------------------------------------------------
# Comma-separated tickers to scan. If blank, the built-in liquid-optionable
# universe in src/lib/screener/universe.ts is used.
SCREEN_UNIVERSE=
# Secret to protect the /api/screen endpoint from public triggering.
# Vercel cron automatically sends this as a Bearer token if set as CRON_SECRET.
CRON_SECRET=
